# Telegram Bot (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Comma-separated Telegram usernames (without @) allowed to use the app
ALLOWED_NICKNAMES=worker1,worker2

# Public URL where the Nuxt app is hosted (must be HTTPS for Telegram Web Apps)
NUXT_PUBLIC_APP_URL=https://your-domain.com

# Supabase — use the service_role key (Settings → API), NOT the publishable/anon key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# Price calculation: price = weight * PRICE_PER_KG
PRICE_PER_KG=1000
